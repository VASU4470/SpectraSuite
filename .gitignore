# Python cache files (Junk files Python creates automatically)
__pycache__/
*.py[cod]
*$py.class

# PyInstaller folders (Created when we build your .exe app later)
build/
dist/
*.spec

# Virtual Environments (If you ever use them)
venv/
env/
.env

# OS specific hidden files (Prevents Mac/Windows junk from uploading)
.DS_Store
Thumbs.db
